{
  "name": "agent-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch --env-file ../../.env src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "check-types": "tsc --noEmit",
    "test": "DB_PATH=:memory: bun test src/__tests__",
    "test:watch": "DB_PATH=:memory: bun test --watch src/__tests__"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "bullmq": "^5.76.6",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.7",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.0",
    "typescript": "5.9.2"
  }
}
