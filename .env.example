# Anthropic
ANTHROPIC_API_KEY=

# Gmail — outbound email sending via nodemailer
# App Password: myaccount.google.com → Security → App Passwords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Postmark — inbound email parsing only (no domain needed)
# Get your inbound address at postmarkapp.com > your server > Inbound
# Set Gmail to forward to: xxx@inbound.postmarkapp.com
WEBHOOK_SECRET=

# Salesforce — create a Connected App in Salesforce Setup > App Manager
# Scopes needed: api, refresh_token
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_REFRESH_TOKEN=
SF_LOGIN_URL=https://login.salesforce.com

# HubSpot — create a Private App in HubSpot > Settings > Integrations > Private Apps
# Scopes needed: crm.objects.contacts.read, crm.objects.contacts.write,
#                crm.objects.deals.read, crm.objects.deals.write
HUBSPOT_ACCESS_TOKEN=

# Redis — required for follow-up scheduling (BullMQ)
# Local: docker run -d -p 6379:6379 redis
# Cloud: Upstash (free tier) at upstash.com
REDIS_URL=redis://localhost:6379

# Notifications
# Slack — create an Incoming Webhook at api.slack.com/apps > Incoming Webhooks
SLACK_WEBHOOK_URL=
# Dashboard base URL — used in notification links (no trailing slash)
DASHBOARD_URL=http://localhost:3000
